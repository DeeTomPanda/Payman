  "query": "\n        UPDATE invoices\n        SET state = $1, updated_at = NOW(), versioning=versioning+1\n        WHERE id = $2 AND business_id = $3 \n        AND versioning = $4\n        RETURNING id, business_id, customer_id,\n        state as \"state: InvoiceState\",\n        total_cents, due_date, created_at, updated_at, versioning\n        ",
