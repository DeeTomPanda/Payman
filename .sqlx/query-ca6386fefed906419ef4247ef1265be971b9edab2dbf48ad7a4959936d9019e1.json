  "query": "\n        SELECT id, invoice_id, retry_count, created_at\n        FROM payment_attempts\n        WHERE status = 'pending'\n        AND (next_retry_at IS NULL OR next_retry_at <= NOW())\n        AND created_at > NOW() - INTERVAL '24 hours'\n        ",
