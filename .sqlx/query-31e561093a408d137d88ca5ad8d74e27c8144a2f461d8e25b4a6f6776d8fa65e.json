{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            wd.id,\n            wd.payload,\n            wd.attempt_count,\n            we.url,\n            we.secret\n        FROM webhook_deliveries wd\n        JOIN webhook_endpoints we ON we.id = wd.webhook_endpoint_id\n        WHERE wd.status = 'pending'\n          AND wd.next_retry_at <= NOW()\n        LIMIT 10\n        ",
